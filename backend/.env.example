# ─────────────────────────────────────────────────────────────
#  Nexus AI — Backend Environment Configuration
#  Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────

# LLM PROVIDER --------------------------------------------------
# Which model provider to use by default.
# Options: "openai" | "anthropic" | "gemini" | "ollama"
LLM_PROVIDER=anthropic

# Anthropic (Claude) — recommended
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Free OpenAI-compatible providers (all have generous free tiers) ──
# Groq — very fast open models · get a free key at https://console.groq.com
GROQ_API_KEY=
# OpenRouter — gateway to many models incl. free ones · https://openrouter.ai
OPENROUTER_API_KEY=
# Cerebras — fast Llama inference · https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Automatic fallback order if the primary provider fails
FALLBACK_CHAIN=["anthropic","openai","gemini","ollama"]

# AGENT SETTINGS ------------------------------------------------
MAX_ITERATIONS=15
MAX_PARALLEL_TOOLS=3
WORKSPACE_PATH=./workspace
ENABLE_HUMAN_CONFIRMATION=true

# MEMORY & RAG --------------------------------------------------
MEMORY_DB_PATH=./data/memory.db
VECTOR_DB_PATH=./data/vectordb
RAG_DB_PATH=./data/ragdb
MAX_MEMORY_ITEMS=1000

# DATABASE ------------------------------------------------------
# Leave unset to use local SQLite. Set to a Postgres URL in production.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# AUTHENTICATION ------------------------------------------------
# Generate a strong secret, e.g.  openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RATE LIMITING -------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# SERVER --------------------------------------------------------
HOST=0.0.0.0
PORT=8000
# Comma/JSON list of allowed frontend origins for CORS
# CORS_ORIGINS=["http://localhost:3000"]

# EMAIL (optional, for the send_email tool) ---------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
